# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables – copy this file to `.env` and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ─── OpenRouter (recommended – cheap, OpenAI-compatible) ─────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model slug – see full list at https://openrouter.ai/models
# Budget-friendly options (sorted cheapest first):
#   openai/gpt-4o-mini          ← default: fast, very cheap, high quality
#   google/gemini-flash-1.5-8b  ← even cheaper, good at structured tasks
#   meta-llama/llama-3.1-8b-instruct:free  ← completely free (rate-limited)
#   mistralai/mistral-7b-instruct:free      ← completely free (rate-limited)
OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── App settings ─────────────────────────────────────────────────────────────
# Where ChromaDB persists its data
CHROMA_PERSIST_DIR=./chroma_db

# Chunk sizes for the text splitter
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Maximum number of retrieved chunks to send to the LLM
TOP_K=5

# ─── Gradio server settings ───────────────────────────────────────────────────
GRADIO_SERVER_PORT=7860
GRADIO_SERVER_NAME=0.0.0.0

# FastAPI backend URL (used by Gradio to call the API)
BACKEND_URL=http://127.0.0.1:8000

# ─── HuggingFace fallback (only used if OPENROUTER_API_KEY is not set) ────────
HF_MODEL=facebook/opt-125m
